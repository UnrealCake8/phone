{
  "name": "uc8phone",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.15",
  "engines": {
    "node": ">=22.0.0",
    "bun": "1.2.15"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "eslint .",
